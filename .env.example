# --- MSSQL (asıl iş veritabanı) ---
MSSQL_SERVER=mssql04.trwww.com
MSSQL_DATABASE=massgrup_cosmo
MSSQL_USER=
MSSQL_PASSWORD=
MSSQL_PORT=1433
MSSQL_ENCRYPT=false
MSSQL_TRUST_CERT=true

# --- next-auth ---
# Üretim için: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# --- Eski PHP portalı (PDF indirme yönlendirmesi) ---
LEGACY_PORTAL_URL=https://portal.uqtest.com

# --- E-posta (Resend) ---
# https://resend.com → API key
RESEND_API_KEY=
# from adresi (doğrulanmış domain) — boş bırakılırsa "noreply@resend.dev" test adresi kullanılır
EMAIL_FROM=
# Yeni destek talepleri admin grubuna mail atar
ADMIN_NOTIFY_EMAIL=

# --- Cron auth ---
# Vercel cron header'ı 'Bearer <CRON_SECRET>' olarak gönderir
CRON_SECRET=

# --- WhatsApp (Twilio) ---
# https://twilio.com → Console → Account SID + Auth Token
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Twilio WhatsApp sender number — örn: whatsapp:+14155238886 (sandbox) veya whatsapp:+905xxxxxxxxx
TWILIO_WHATSAPP_NUMBER=
# Inbound webhook'u korumak için (URL'e ?secret=xxx olarak eklenecek)
WHATSAPP_WEBHOOK_SECRET=
# Onaylı template SID'leri (Twilio Content API → Content Templates → HX...)
# Yoksa cron WA outbound bildirimleri skip eder (sadece text mesajlar gider)
TWILIO_WA_TEMPLATE_RAPOR_SID=
TWILIO_WA_TEMPLATE_TEKLIF_SID=

# --- Site ayarları ---
SITE_NAME=UNIQUE Services Portal
SITE_LOGO_URL=/logo.png
